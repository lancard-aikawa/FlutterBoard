# FlutterBoard 環境変数サンプル
# ---------------------------------------------------------------
# このファイルは dotenv では読み込まれません（依存なし）。
# 各変数はシステムの環境変数として設定するか、
# start.cmd / npm run dev の前に export してください。
# ---------------------------------------------------------------

# ── サーバー ────────────────────────────────────────────────────
PORT=3210
APP_ENV=development

# ── Flutter ツールチェイン ──────────────────────────────────────
# FLUTTER_ROOT=C:\flutter
# ANDROID_HOME=C:\Users\username\AppData\Local\Android\Sdk
# JAVA_HOME=C:\Program Files\Android\Android Studio\jbr
# FVM_HOME=C:\Users\username\fvm

# ── Firebase ────────────────────────────────────────────────────
FIREBASE_PROJECT=my-flutter-app-dev
FIREBASE_EMULATOR_HUB_HOST=localhost
FIREBASE_EMULATOR_HUB_PORT=4400
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ── アプリ設定 ──────────────────────────────────────────────────
API_BASE_URL=http://localhost:3210
APP_NAME=FlutterBoard

# ── 機密情報（値はマスク表示されます）──────────────────────────
# FIREBASE_TOKEN=your-ci-token
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# API_SECRET_KEY=your-secret
